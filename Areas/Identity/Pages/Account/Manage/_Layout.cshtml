@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Areas/Identity/Pages/_Layout.cshtml";
    }
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="card shadow-sm border-3">
                <div class="card-body">
                    <h5 class="card-title text-dark">Settings</h5>
                    <hr />
                    <partial name="_ManageNav" />
                </div>
            </div>
        </div>
        <div class="col-md-9">
            <div class="card shadow-sm border-3">
                <div class="card-body">
                    <h1 class="h3 text-dark">Manage Your Account</h1>
                    <p class="text-muted">Modify your account settings below.</p>
                    <hr />
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
